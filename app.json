{
  "expo": {
    "name": "Karny Budget",
    "slug": "karny-budget",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.karny.budget"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f5c028b7-a970-4593-9b1b-e609aa241d6b"
    },
    "android": {
      "package": "app.karny.budget",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#C8F135"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Karny Budget to use Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Karny Budget to access your photos."
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      "expo-localization",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "karny-budget",
    "extra": {
      "eas": {
        "projectId": "f5c028b7-a970-4593-9b1b-e609aa241d6b"
      },
      "router": {}
    },
    "owner": "maknessiahmed"
  }
}
